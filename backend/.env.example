# ============================================================
# FlowrexAlgo — Environment Variables
# Copy this file to .env (local) or set in Render Dashboard
# ============================================================

# --- Debug Mode ---
# Set to true for local development (adds localhost CORS origins)
DEBUG=false

# --- Database ---
# Local: SQLite (default, no config needed)
# Render: PostgreSQL connection string
DATABASE_URL=sqlite:///./data/flowrexalgo.db
# DATABASE_URL=postgresql://user:password@host:5432/flowrexalgo

# --- Auth / Security ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-string

# --- Frontend URL (CORS — no trailing slash) ---
# Local: http://localhost:3000
# Render: https://your-frontend.onrender.com
FRONTEND_URL=http://localhost:3000

# --- File Uploads ---
UPLOAD_DIR=./data/uploads

# --- News APIs ---
# Finnhub: https://finnhub.io (free tier available)
FINNHUB_API_KEY=your-finnhub-api-key

# Alpha Vantage: https://www.alphavantage.co (free tier available)
ALPHAVANTAGE_API_KEY=your-alphavantage-api-key

# --- SMTP (Email Notifications, Invitations, 2FA) ---
# Gmail example: smtp.gmail.com / 587 / your-email@gmail.com / app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_EMAIL=notifications@yourdomain.com

# --- Telegram Bot (Notifications) ---
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- Market Data: Databento (CME Futures) ---
# Sign up: https://databento.com  |  Pricing: ~$199/mo, $125 free credits on signup
# Supports: XAUUSD (GC), XAGUSD (SI), US30 (YM), NAS100 (NQ), BTC, EURUSD (6E)
# Leave empty to use Oanda/broker data (default)
DATABENTO_API_KEY=your-databento-api-key
