# Python cache
__pycache__/
*.py[cod]

# Local environments
.venv/
venv/
env/

# Local secrets/config
.env
.env.*
!.env.example

# Runtime logs/artifacts
*.log
build_output.txt
frontend_log.txt

# Project local data artifacts
backend/data/ml_models/
# Allow small ONNX deploy files (needed for Render)
!backend/data/ml_models/*.onnx
!backend/data/ml_models/*.onnx.data
!backend/data/ml_models/*.npz
backend/data/*.db
backend/*.db
nul

# Include CSV uploads in repo (needed for Render ephemeral filesystem)
# Large legacy files excluded individually:
backend/data/uploads/DIA_5m_5Yea.csv
backend/data/uploads/EURUSD_5m_2Yea.csv
backend/data/uploads/SPY_5m_1Yea.csv
